jv.error.locale_missing = "missing locale after --locale"
jv.error.locale_empty = "locale must not be empty"
jv.error.unknown_option = "unknown option: {option}"
jv.error.too_many_arguments = "too many arguments"
jv.error.missing_url = "URL ora ana"
jv.error.fetch_exception = "jupuk gagal before completion"
jv.version = "sitefetch {version}"
jv.start.fetching = "njupuk: {url}"
jv.start.target = "tujuan:   {target}"
