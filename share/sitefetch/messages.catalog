default_locale = en
en.usage.line1 = "usage: sitefetch [--help] [--version]"
en.usage.line2 = "       sitefetch [--quiet|-q] [--verbose|-v] [--locale LOCALE] [--jsonl] [--json-summary] [--max-pages N] [--max-depth N] [--max-bytes N] [--max-failures N] [--retries N] [--retry-delay-ms N] [--retry-jitter-ms N] [--request-delay-ms N] [--workers N] [--skip-dangerous] [--safe] [--head MODE] [--robots] [--cache MODE] [--incremental] [--refresh-cache] [--offline-cache] [--cache-max-stale-ms N] [--cache-hash MODE] [--cache-documents-only|--cache-downloads-only] [--cache-require-version] [--cache-no-verify-local] [--user-agent UA] [--accept-language VALUE] [--accept-encoding VALUE] [--include-parent-domains] URL [target]"
en.usage.description = "Fetch a website recursively into target, or the current directory."
en.usage.scheme = "URLs without http:// or https:// are fetched with http://."
en.usage.quiet = "Use --quiet or -q to suppress progress and summary output."
en.usage.verbose = "Use --verbose or -v to show cache, retry, resume, robots, and skip diagnostics."
en.usage.locale = "Use --locale LOCALE to override the detected system locale."
en.error.prefix = "sitefetch: {message}"
en.error.target_empty = "target path must not be empty"
en.error.target_not_directory = "target exists but is not a directory: {target}"
en.error.target_inspect = "cannot inspect target path: {target}"
en.error.locale_missing = "missing locale after --locale"
en.error.locale_empty = "locale must not be empty"
en.error.unknown_option = "unknown option: {option}"
en.error.too_many_arguments = "too many arguments"
en.error.missing_url = "missing URL"
en.error.fetch_exception = "fetch failed before completion"
en.version = "sitefetch {version}"
en.start.fetching = "fetching: {url}"
en.start.target = "target:   {target}"
en.status.completed = "completed"
en.status.failed = "failed"
en.status.failed_reason = "failed: {reason}"
en.summary.attempted = "attempted: {count}"
en.summary.written = "written:   {count}"
en.summary.external = "external:  {count}"
en.summary.ignored = "ignored:   {count}"
en.summary.failed = "failed:   {count}"
en.summary.elapsed = "elapsed:  {duration}"
en.summary.failed_url = "failed URL: {url}"
en.summary.failed_reason = "failure reason: {reason}"
en.progress.fetch = "fetch:    {url}"
en.progress.write = "write:    {url}"
en.progress.external = "external: {url}"
en.progress.ignore = "ignore:   {url}"
en.progress.danger = "danger:  {url}"
en.progress.skip_danger = "blocked: {url}"
en.progress.visited = "visited:  {url}"
en.progress.fail = "fail:     {url}"
en.progress.cache_revalidate = "cache:   {url}"
en.progress.cache_reused = "cached:  {url}"
en.progress.cache_rejected = "cache-skip: {url}"
en.progress.resume = "resume:  {url}"
en.progress.retry = "retry:   {url}"
en.progress.robots_allow = "robots: {url}"
