jv.meta.provisional = "true"
jv.usage.line1 = "panggunaan: sitefetch [--help] [--version]"
jv.usage.line2 = "       sitefetch [--quiet|-q] [--verbose|-v] [--locale LOCALE] [--jsonl] [--json-summary] [--max-pages N] [--max-depth N] [--max-bytes N] [--max-failures N] [--retries N] [--retry-delay-ms N] [--retry-jitter-ms N] [--request-delay-ms N] [--workers N] [--skip-dangerous] [--safe] [--head MODE] [--robots] [--cache MODE] [--incremental] [--refresh-cache] [--offline-cache] [--cache-max-stale-ms N] [--cache-hash MODE] [--cache-documents-only|--cache-downloads-only] [--cache-require-version] [--cache-no-verify-local] [--user-agent UA] [--accept-language VALUE] [--accept-encoding VALUE] [--include-parent-domains] URL [tujuan]"
jv.usage.description = "Jupuk a website recursively into tujuan, or the current directory."
jv.usage.scheme = "URLs without http:// or https:// are fetched with http://."
jv.usage.quiet = "Use --quiet or -q to hide progress and summary output."
jv.usage.verbose = "Gunakake --verbose utawa -v kanggo nuduhake diagnostik cache, nyoba maneh, nerusake, robots lan ngliwati."
jv.usage.locale = "Use --locale LOCALE to override the detected locale."
jv.error.prefix = "sitefetch: {message}"
jv.error.target_empty = "tujuan path must not be empty"
jv.error.target_not_directory = "tujuan exists but is not a directory: {target}"
